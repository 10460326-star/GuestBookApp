@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>個人專屬日記本 - 登入</title>
    <style>
            body {
                font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
                background: #e9ecef;
                margin: 0;
            }

            .login-box {
                background: white;
                padding: 40px;
                border-radius: 10px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                width: 100%;
                max-width: 350px;
                text-align: center;
            }

            h2 {
                color: #495057;
                margin-bottom: 25px;
                letter-spacing: 1px;
            }

            input {
                width: 100%;
                padding: 12px;
                margin-bottom: 15px;
                border: 1px solid #ced4da;
                border-radius: 5px;
                box-sizing: border-box;
                font-size: 1rem;
            }

            button {
                background: #28a745;
                color: white;
                width: 100%;
                padding: 12px;
                border: none;
                border-radius: 5px;
                font-size: 1rem;
                cursor: pointer;
                transition: background 0.2s;
            }

                button:hover {
                    background: #218838;
                }

            .error {
                color: #dc3545;
                font-size: 0.9rem;
                margin-bottom: 15px;
                background: #f8d7da;
                padding: 10px;
                border-radius: 5px;
                border: 1px solid #f5c6cb;
            }

            .hint {
                color: #6c757d;
                font-size: 0.85rem;
                margin-top: 25px;
                text-align: left;
                background: #f8f9fa;
                padding: 12px;
                border-radius: 4px;
                border-left: 4px solid #17a2b8;
                line-height: 1.6;
            }
    </style>
</head>
<body>

    <div class="login-box">
        <h2>🔒 雲端專屬日記本</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error">❌ @ViewBag.Error</div>
        }

        <form action="/Home/DoLogin" method="post">
            <input type="text" name="username" placeholder="請輸入使用者帳號" required autocomplete="off" />
            <input type="password" name="password" placeholder="請輸入密碼" required />
            <button type="submit">登入系統</button>
        </form>

        <div class="hint">
            <strong>💡 測試帳密提示（已內建於 SQL）：</strong><br>
            👤 帳號：<code>userA</code> ｜ 🔑 密碼：<code>1234</code><br>
            👤 帳號：<code>userB</code> ｜ 🔑 密碼：<code>5678</code>
        </div>
    </div>

</body>
</html>